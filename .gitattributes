# Keep Go sources LF everywhere so gofmt agrees across platforms.
* text=auto
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
LICENSE text eol=lf
# Bash reads these verbatim; CRLF would break the version parser on Windows runners.
*.sh text eol=lf
.easysftp-version text eol=lf
